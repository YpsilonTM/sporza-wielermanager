{
  "name": "sporza-wielermanager",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run db:generate && bun --bun run vite dev",
    "build": "svelte-kit sync && bunx --bun prisma generate && bun --bun run vite build",
    "preview": "bun --bun run vite preview",
    "start": "bun ./build/index.js",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "bun test src/lib/server/rules.test.js src/lib/server/transfers.test.js src/lib/server/format.test.ts src/lib/server/job-side-effects.test.js src/lib/server/mini-competitions.test.js",
    "typecheck": "bun run check",
    "db:generate": "bunx --bun prisma generate",
    "db:migrate": "bunx --bun prisma migrate dev",
    "db:migrate:deploy": "bunx --bun prisma migrate deploy",
    "auth-refresh": "bun run scripts/cli.js auth-refresh",
    "cyclists": "bun run scripts/cli.js cyclists",
    "team": "bun run scripts/cli.js team",
    "roster": "bun run scripts/cli.js roster",
    "lineup": "bun run scripts/cli.js lineup",
    "manage": "bun run scripts/cli.js manage",
    "import-cookies": "bun run scripts/cli.js import-cookies",
    "probe": "bun run scripts/discovery/probe-endpoints.js"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@libsql/client": "^0.17.4",
    "@lucide/svelte": "^1.21.0",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "croner": "^10.0.1",
    "dotenv": "^17.4.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "1.61.0",
    "prisma": "^7.8.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@sveltejs/kit": "^2.65.2",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.1",
    "@types/bun": "^1.3.14",
    "svelte": "^5.56.3",
    "svelte-adapter-bun": "^1.0.1",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
