# Edition slug (Tour 2026 mannen)
EDITION_SLUG=tour-m-26

# ── Auth (pick one) ──────────────────────────────────────────────

# Recommended: paste Cookie header from browser (no Playwright needed)
# DevTools → Network → wielermanager.sporza.be request → Request Headers → Cookie
# WIELERMANAGER_COOKIES_FILE=.wielermanager_cookies.json
# WIELERMANAGER_COOKIE_HEADER=sporza-site_profile_at=...; other=cookies

# Or import cookies manually (no browser automation):
# bun run import-cookies --header "sporza-site_profile_at=...; ..."

# VRT login (for auth-refresh)
VRT_EMAIL=your-email@example.com
VRT_PASSWORD=your-password

# Browser for auth-refresh
# auto = system Chrome locally, bundled Chromium in Docker (see RUNNING_IN_DOCKER)
# BROWSER_MODE=auto
# RUNNING_IN_DOCKER=true          # set in Dockerfile
# PLAYWRIGHT_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
# HEADLESS=true
# AUTH_DEBUG_SCREENSHOTS=true   # login failure screenshots → DATA_DIR/auth-debug/

# AI (lineup/transfer beslissingen)
GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_ESCALATION_MODEL=gemini-2.5-pro

# Server / scheduler
# PORT=3000
# AUTO_MANAGE_WINDOW_MS=3600000
# CRON_CHECK_MINUTES=15
# ALLOW_AUTO_TRANSFERS=false       # auto-manage never transfers unless true
# DASHBOARD_API_KEY=               # optional: protect /api/run/*, /api/logs, /api/decisions/*
# NOTIFY_WEBHOOK_URL=              # optional: Discord/ntfy webhook for auto-manage & job events

# Auth refresh happens automatically on 401/403 when VRT credentials are configured.
# Manual: bun run auth-refresh

# Transfers (CLI)
# manage --submit only submits lineups; add --allow-transfers for real swaps
# Before race 1: use `bun run roster --submit` (free), not transfers

# Data
# DATA_DIR=./data
# DATABASE_URL=file:./data/wielermanager.db
# HEADLESS=true
